result.json
docs/status.json
# UiPath Studio project file — not needed for coded agents
project.uiproj

# ── UiPath generated schema files ────────────────────────────────
# Auto-generated by `uv run uipath init` — fill in locally, do not commit
entry-points.json
uipath.json

# ── Demo portal config (contains live credentials) ───────────────
docs/portal_config.js
docs/serve_config.py

# ── Local development documentation ───────────────────────────────
