# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.venv/

# ── Environment & credentials ─────────────────────────────────────
.env

# ── UiPath auth & runtime artifacts ──────────────────────────────
# .uipath/ contains auth tokens managed by `uipath auth` — never commit
.uipath/
# __uipath/ contains runtime state (state.db etc.)
__uipath/
